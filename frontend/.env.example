# =========================================================================
# VoxReader AI - Environment Configuration Example
# Copy this file to a new file named '.env' in this directory to load custom configs:
# cp .env.example .env
# =========================================================================

# The application brand name shown in the Header, Landing screen and Page title
VITE_APP_TITLE="VoxReader AI"

# Default voice language filter when initializing Speech Synthesis (e.g. 'en-US')
VITE_DEFAULT_LANG="en-US"

# Build configuration details
VITE_BUILD_STAMP="v1.0.0-production"
